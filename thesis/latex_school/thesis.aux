\@writefile{lof}{\contentsline {figure}{\numberline {8.1}{\ignorespaces M0: with divergent features, rank-training beats regression on the matching ratio (left) \emph  {despite} a worse regression fit (right) --- the dissociation that shows regression is the wrong training objective for MPD.}}{40}{figure.8.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8.2}{\ignorespaces M3 --- the decisive negative on a real trace (Azure LLM): with real arrivals and real temporal features, the rank-trained and MSE-trained predictors are indistinguishable from each other and from the non-learned last-window count, all near the oracle; the engineered order/magnitude divergence that powers rank-training does not arise.}}{41}{figure.8.2}\protected@file@percent }
