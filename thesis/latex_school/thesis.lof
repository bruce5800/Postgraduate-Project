\contentsline {chapteratlist}{\numberline {2}Background and Related Work}{5}{chapter.2}%
\contentsline {chapteratlist}{\numberline {3}Model, Algorithms, and Methodology}{11}{chapter.3}%
\contentsline {figure}{\numberline {3.1}{\ignorespaces Erdős--Rényi reproduction (competitive ratio vs edge density \(c\)): the characteristic U-shape, greedy minima near \(c\approx 4.9\), and non-greedy degradation as \(c\) grows.}}{15}{figure.3.1}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces Random left-regular reproduction (competitive ratio vs left-degree \(d\)): the hard case at \(d=5\), Greedy \(\approx \) Ranking, non-greedy degradation.}}{16}{figure.3.2}%
\contentsline {chapteratlist}{\numberline {4}The Unified Benchmark}{19}{chapter.4}%
\contentsline {figure}{\numberline {4.1}{\ignorespaces The unified benchmark: competitive ratio (mean, 95\% CI) versus prediction quality, for the three panels. Naive followers (MPD under adversarial, FollowPrediction) dip below the advice-free floor; the robust algorithms do not.}}{22}{figure.4.1}%
\contentsline {figure}{\numberline {4.2}{\ignorespaces The consistency--robustness plane, one point per algorithm (consistency = ratio under perfect advice; robustness = worst ratio across advice quality; the data of Table 4.1). Dashed lines mark the advice-free floor, dotted the oracle ceiling. Naive followers (MPD, FollowPrediction) buy consistency with robustness; the structural augmentations give up little of either; TestAndMatch sits nearest the ideal top-right corner; the combiner stays pinned at the floor point.}}{23}{figure.4.2}%
\contentsline {chapteratlist}{\numberline {5}What Governs the Loss: Order Error and ACI's Bound}{25}{chapter.5}%
\contentsline {figure}{\numberline {5.1}{\ignorespaces Order error governs the loss. (a) The realized MPD loss lies far below ACI's \(n-\mathrm {LIS}\) upper bound and \(n-\mathrm {LIS}\) saturates. (b) The loss collapses onto the Kendall-\(\tau \) order error across all four error models.}}{26}{figure.5.1}%
\contentsline {chapteratlist}{\numberline {6}Test-and-Fallback in Depth}{29}{chapter.6}%
\contentsline {figure}{\numberline {6.1}{\ignorespaces The robustness envelope. As advice error \(\ell _1(p,q)\) grows, blind FollowPrediction crashes below the advice-free floor, while TestAndMatch (Choo/BEM) stays on the upper envelope.}}{30}{figure.6.1}%
\contentsline {figure}{\numberline {6.2}{\ignorespaces Testing cost at borderline advice: a larger, more accurate prefix test makes the \emph {worse} decision, because the worst-case-calibrated threshold accepts mildly-bad advice on strong-baseline inputs.}}{32}{figure.6.2}%
\contentsline {figure}{\numberline {6.3}{\ignorespaces Recalibration removes the threshold pathology: at borderline advice the worst-case-calibrated threshold's misjudgement rate climbs toward \(1.0\) as the prefix grows, while the threshold recalibrated to the measured baseline holds it at zero --- but its acceptance margin then falls below the estimator's noise floor, so it can never confidently accept.}}{33}{figure.6.3}%
\contentsline {chapteratlist}{\numberline {7}External Validity}{35}{chapter.7}%
\contentsline {figure}{\numberline {7.1}{\ignorespaces A real, cheap predictor (Wikipedia trace). (a) Topology aggregation halves the induced degree predictor's order error relative to the raw histogram. (b) A stale forecast tracks the oracle through the degree route while blind histogram-following decays.}}{36}{figure.7.1}%
\contentsline {figure}{\numberline {7.2}{\ignorespaces F1--F3 on six real graphs. Naive MPD (red) dips below the Ranking floor under adversarial predictions on every graph; the structural augmentations (green/blue) stay flat --- as on synthetic graphs.}}{37}{figure.7.2}%
\contentsline {chapteratlist}{\numberline {8}Exploratory Directions and Negative Results}{39}{chapter.8}%
\contentsline {figure}{\numberline {8.1}{\ignorespaces M0: with divergent features, rank-training beats regression on the matching ratio (left) \emph {despite} a worse regression fit (right) --- the dissociation that shows regression is the wrong training objective for MPD.}}{40}{figure.8.1}%
\contentsline {figure}{\numberline {8.2}{\ignorespaces M3 --- the decisive negative on a real trace (Azure LLM): with real arrivals and real temporal features, the rank-trained and MSE-trained predictors are indistinguishable from each other and from the non-learned last-window count, all near the oracle; the engineered order/magnitude divergence that powers rank-training does not arise.}}{41}{figure.8.2}%
\contentsline {figure}{\numberline {8.3}{\ignorespaces Serving SLO probe: on a tight-SLO/tail objective under bursty load, a non-predictive policy (static headroom or reactive-adaptive) matches the clairvoyant oracle to within a few percent --- foresight does not help.}}{43}{figure.8.3}%
\contentsline {chapteratlist}{\numberline {9}The Impossibility Theorem: Why the Wall Is Necessary}{45}{chapter.9}%
\contentsline {figure}{\numberline {9.1}{\ignorespaces The impossibility, numerically (the ``scissors''). Left: the \emph {potential} upside grows as the baseline weakens, but the upside a sublinear test can \emph {safely capture} stays near zero. Right: the test's empirical-\(\ell _1\) resolution sits far above the break-even margin wherever an upside exists.}}{46}{figure.9.1}%
\contentsline {chapteratlist}{\numberline {10}Application Case Study: AI-Inference Serving}{51}{chapter.10}%
\contentsline {figure}{\numberline {10.1}{\ignorespaces Capacity as robustness: as forecast error grows, blindly following the forecast crashes goodput at both capacities --- and \emph {deeper} at ample capacity (\(c=8\)) --- while the adaptive test stays flat at the capacity-aware baseline.}}{52}{figure.10.1}%
\contentsline {figure}{\numberline {10.2}{\ignorespaces Forecasts vs live load (real LLM timestamps and service times): a forecast-free least-loaded balancer is robust at every capacity, while blindly following a stale forecast degrades with its error; an adaptive test recovers most of the gap.}}{53}{figure.10.2}%
\contentsline {figure}{\numberline {10.3}{\ignorespaces The cache-affinity reversal (real Mooncake prefix trace): for KV-cache reuse, a \emph {stable} consistent-hash placement beats reactive routing --- the opposite of the load-balancing case --- because cache locality rewards persistence.}}{54}{figure.10.3}%
