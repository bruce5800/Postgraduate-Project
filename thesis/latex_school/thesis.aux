\@writefile{lof}{\contentsline {figure}{\numberline {6.2}{\ignorespaces Testing cost at borderline advice: a larger, more accurate prefix test makes the \emph  {worse} decision, because the worst-case-calibrated threshold accepts mildly-bad advice on strong-baseline inputs.}}{32}{figure.6.2}\protected@file@percent }
\BKM@entry{id=34,dest={73656374696F6E2E362E34},srcline={106}}{}
\@writefile{lof}{\contentsline {figure}{\numberline {6.3}{\ignorespaces Recalibration removes the threshold pathology: at borderline advice the worst-case-calibrated threshold's misjudgement rate climbs toward \(1.0\) as the prefix grows, while the threshold recalibrated to the measured baseline holds it at zero --- but its acceptance margin then falls below the estimator's noise floor, so it can never confidently accept.}}{33}{figure.6.3}\protected@file@percent }
